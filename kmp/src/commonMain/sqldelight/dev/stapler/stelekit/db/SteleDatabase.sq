-- Logseq Database Schema
-- Core entities for note-taking application

CREATE TABLE pages (
    uuid TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL COLLATE NOCASE,
    namespace TEXT,
    file_path TEXT,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL,
    properties TEXT, -- JSON string for page properties
    version INTEGER NOT NULL DEFAULT 0,
    is_favorite INTEGER DEFAULT 0,
    is_journal INTEGER DEFAULT 0,
    journal_date TEXT,
    is_content_loaded INTEGER NOT NULL DEFAULT 1,
    backlink_count INTEGER NOT NULL DEFAULT 0,
    section_id TEXT NOT NULL DEFAULT '',
    UNIQUE(name, section_id)
);

CREATE TABLE blocks (
    id INTEGER PRIMARY KEY AUTOINCREMENT, -- Hidden numeric ID for FTS5 internal use
    uuid TEXT NOT NULL UNIQUE,
    page_uuid TEXT NOT NULL,
    parent_uuid TEXT,
    left_uuid TEXT,
    content TEXT NOT NULL,
    level INTEGER NOT NULL DEFAULT 0,
    position TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL,
    properties TEXT, -- JSON string for block properties
    version INTEGER NOT NULL DEFAULT 0,
    content_hash TEXT, -- SHA-256 hex digest of normalised content (used for deduplication)
    block_type TEXT NOT NULL DEFAULT 'bullet', -- Structural discriminator (bullet, paragraph, heading, etc.) — excluded from FTS intentionally
    FOREIGN KEY (page_uuid) REFERENCES pages(uuid) ON DELETE CASCADE,
    FOREIGN KEY (parent_uuid) REFERENCES blocks(uuid) ON DELETE CASCADE,
    FOREIGN KEY (left_uuid) REFERENCES blocks(uuid) ON DELETE SET NULL
);

CREATE TABLE properties (
    uuid TEXT NOT NULL PRIMARY KEY,
    block_uuid TEXT NOT NULL,
    key TEXT NOT NULL,
    value TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    FOREIGN KEY (block_uuid) REFERENCES blocks(uuid) ON DELETE CASCADE
);

CREATE TABLE plugin_data (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    plugin_id TEXT NOT NULL,
    entity_type TEXT NOT NULL,
    entity_uuid TEXT NOT NULL,
    key TEXT NOT NULL,
    value TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER,
    UNIQUE(plugin_id, entity_type, entity_uuid, key)
);

CREATE TABLE block_references (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    from_block_uuid TEXT NOT NULL,
    to_block_uuid TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    UNIQUE(from_block_uuid, to_block_uuid),
    FOREIGN KEY (from_block_uuid) REFERENCES blocks(uuid) ON DELETE CASCADE,
    FOREIGN KEY (to_block_uuid) REFERENCES blocks(uuid) ON DELETE CASCADE
);

CREATE INDEX idx_pages_namespace ON pages(namespace);
CREATE INDEX idx_blocks_page_position ON blocks(page_uuid, position);
CREATE INDEX idx_blocks_parent_position ON blocks(parent_uuid, position);
CREATE INDEX idx_blocks_page_hash ON blocks(page_uuid, uuid, content_hash);
CREATE INDEX idx_blocks_left_uuid ON blocks(left_uuid);
CREATE INDEX idx_blocks_content_hash ON blocks(content_hash);
CREATE INDEX idx_properties_block_uuid ON properties(block_uuid);
CREATE INDEX idx_properties_key ON properties(key);
CREATE INDEX idx_plugin_data_plugin_id ON plugin_data(plugin_id);
CREATE INDEX idx_plugin_data_entity ON plugin_data(entity_type, entity_uuid);
CREATE INDEX idx_plugin_data_key ON plugin_data(key);
CREATE INDEX idx_references_from ON block_references(from_block_uuid);
CREATE INDEX idx_references_to ON block_references(to_block_uuid);
CREATE INDEX idx_pages_journal ON pages(is_journal, journal_date DESC);
CREATE INDEX idx_pages_updated_at ON pages(updated_at DESC);
CREATE INDEX idx_pages_created_at ON pages(created_at DESC);
CREATE INDEX idx_pages_favorite ON pages(name) WHERE is_favorite = 1;
CREATE INDEX idx_pages_journal_section ON pages(is_journal, journal_date, section_id);
CREATE INDEX idx_pages_section_id ON pages(section_id, name);

-- Migration Framework Changelog
CREATE TABLE migration_changelog (
    id              TEXT NOT NULL,
    graph_id        TEXT NOT NULL,
    description     TEXT NOT NULL,
    checksum        TEXT NOT NULL,
    applied_at      INTEGER NOT NULL,
    execution_ms    INTEGER NOT NULL DEFAULT 0,
    status          TEXT NOT NULL DEFAULT 'APPLIED',
    applied_by      TEXT NOT NULL DEFAULT '',
    execution_order INTEGER NOT NULL DEFAULT 0,
    changes_applied INTEGER NOT NULL DEFAULT 0,
    error_message   TEXT,
    PRIMARY KEY (id, graph_id)
);

CREATE INDEX idx_changelog_graph_status ON migration_changelog(graph_id, status);
CREATE INDEX idx_changelog_applied_at ON migration_changelog(graph_id, applied_at);

-- FTS5 Full-Text Search virtual table for blocks
CREATE VIRTUAL TABLE blocks_fts USING fts5(
    content,
    content=blocks,
    content_rowid=id,
    tokenize='porter unicode61'
);

-- FTS5 Full-Text Search virtual table for page names
CREATE VIRTUAL TABLE pages_fts USING fts5(
    name,
    content=pages,
    content_rowid=rowid,
    tokenize='porter unicode61'
);

-- FTS5 triggers for automatic index synchronization
-- Insert trigger
CREATE TRIGGER blocks_ai AFTER INSERT ON blocks BEGIN
    INSERT INTO blocks_fts(rowid, content) VALUES (new.id, new.content);
END;

-- Delete trigger
CREATE TRIGGER blocks_ad AFTER DELETE ON blocks BEGIN
    INSERT INTO blocks_fts(blocks_fts, rowid, content)
    VALUES('delete', old.id, old.content);
END;

-- Update trigger — scoped to content only so position/level/left_uuid changes
-- (emitted by splitBlock, indentBlock, moveBlock sibling shifts) don't trigger
-- O(n) FTS5 delete+insert pairs per structural edit.
CREATE TRIGGER blocks_au AFTER UPDATE OF content ON blocks BEGIN
    INSERT INTO blocks_fts(blocks_fts, rowid, content)
    VALUES('delete', old.id, old.content);
    INSERT INTO blocks_fts(rowid, content) VALUES (new.id, new.content);
END;

-- FTS5 triggers for pages_fts automatic index synchronization
CREATE TRIGGER pages_ai AFTER INSERT ON pages BEGIN
    INSERT INTO pages_fts(rowid, name) VALUES (new.rowid, new.name);
END;

CREATE TRIGGER pages_ad AFTER DELETE ON pages BEGIN
    INSERT INTO pages_fts(pages_fts, rowid, name) VALUES('delete', old.rowid, old.name);
END;

CREATE TRIGGER pages_au AFTER UPDATE OF name ON pages BEGIN
    INSERT INTO pages_fts(pages_fts, rowid, name) VALUES('delete', old.rowid, old.name);
    INSERT INTO pages_fts(rowid, name) VALUES (new.rowid, new.name);
END;

-- Visit tracking table — one row per page, updated on each navigation
CREATE TABLE IF NOT EXISTS page_visits (
    page_uuid       TEXT NOT NULL PRIMARY KEY,
    visit_count     INTEGER NOT NULL DEFAULT 0,
    last_visited_at INTEGER NOT NULL   -- epoch milliseconds (Unix)
);

-- Wikilink reference index: one row per (block, page_name) wikilink.
-- Replaces the O(blocks) LIKE scan in recomputeBacklinkCountForPage.
-- ON DELETE CASCADE keeps the index consistent when blocks are deleted.
-- WITHOUT ROWID: removes the hidden rowid B-tree — all lookups are composite PK lookups.
CREATE TABLE IF NOT EXISTS wikilink_references (
    block_uuid TEXT NOT NULL,
    page_name  TEXT NOT NULL COLLATE NOCASE,
    PRIMARY KEY (block_uuid, page_name),
    FOREIGN KEY (block_uuid) REFERENCES blocks(uuid) ON DELETE CASCADE
) WITHOUT ROWID;

CREATE INDEX IF NOT EXISTS idx_wikilink_refs_page_name ON wikilink_references(page_name COLLATE NOCASE);

-- Repository queries

-- Block queries
selectBlockByUuid:
SELECT * FROM blocks WHERE uuid = ?;

selectBlocksByUuids:
SELECT * FROM blocks WHERE uuid IN ?;

existsBlockByUuid:
SELECT COUNT(*) FROM blocks WHERE uuid = ?;

selectAllBlocks:
SELECT * FROM blocks ORDER BY uuid;

selectAllBlocksPaginated:
SELECT * FROM blocks ORDER BY uuid LIMIT ? OFFSET ?;

selectAllBlocksPaginatedAfterUuid:
SELECT * FROM blocks WHERE uuid > ? ORDER BY uuid LIMIT ?;

selectBlockChildren:
SELECT * FROM blocks WHERE parent_uuid = ? ORDER BY position LIMIT ? OFFSET ?;

countBlockChildren:
SELECT COUNT(*) FROM blocks WHERE parent_uuid = ?;

selectBlockSiblings:
SELECT * FROM blocks 
WHERE parent_uuid IS (SELECT parent_uuid FROM blocks WHERE uuid = ?) 
AND page_uuid = (SELECT page_uuid FROM blocks WHERE uuid = ?)
AND uuid != ? 
ORDER BY position;

selectRootBlocks:
SELECT * FROM blocks WHERE parent_uuid IS NULL AND page_uuid = ? ORDER BY position LIMIT ? OFFSET ?;

countRootBlocks:
SELECT COUNT(*) FROM blocks WHERE parent_uuid IS NULL AND page_uuid = ?;

selectBlocksByPageUuid:
SELECT * FROM blocks WHERE page_uuid = ? ORDER BY position LIMIT ? OFFSET ?;

selectBlocksByPageUuidUnpaginated:
SELECT * FROM blocks WHERE page_uuid = ? ORDER BY position;

selectBlocksWithContentLike:
SELECT * FROM blocks WHERE content LIKE ?;

selectBlocksWithContentLikePaginated:
SELECT * FROM blocks WHERE content LIKE ? ORDER BY created_at DESC LIMIT ? OFFSET ?;

countBlocksByPageUuid:
SELECT COUNT(*) FROM blocks WHERE page_uuid = ?;

updateBlockParent:
UPDATE blocks SET parent_uuid = ? WHERE uuid = ?;

selectBlocksByParentUuidOrdered:
SELECT * FROM blocks WHERE parent_uuid = ? ORDER BY position;

selectBlocksByParentUuids:
SELECT * FROM blocks WHERE parent_uuid IN ? ORDER BY parent_uuid, position;

selectBlockHierarchyRecursive:
WITH RECURSIVE subtree(
    id, uuid, page_uuid, parent_uuid, left_uuid, content, level, position,
    created_at, updated_at, properties, version, content_hash, block_type, depth
) AS (
    SELECT b.id, b.uuid, b.page_uuid, b.parent_uuid, b.left_uuid, b.content,
           b.level, b.position, b.created_at, b.updated_at, b.properties,
           b.version, b.content_hash, b.block_type, 0 AS depth
    FROM blocks b
    WHERE b.uuid = ?
    UNION ALL
    SELECT b.id, b.uuid, b.page_uuid, b.parent_uuid, b.left_uuid, b.content,
           b.level, b.position, b.created_at, b.updated_at, b.properties,
           b.version, b.content_hash, b.block_type, s.depth + 1
    FROM blocks b
    INNER JOIN subtree s ON b.parent_uuid = s.uuid
    WHERE s.depth < 100
)
SELECT * FROM subtree
ORDER BY depth, parent_uuid, position;

selectRootBlocksByPageUuidOrdered:
SELECT * FROM blocks WHERE parent_uuid IS NULL AND page_uuid = ? ORDER BY position;

updateBlockParentPositionAndLevel:
UPDATE blocks SET parent_uuid = ?, position = ?, level = ? WHERE uuid = ?;

updateBlockHierarchy:
UPDATE blocks SET parent_uuid = ?, left_uuid = ?, position = ?, level = ? WHERE uuid = ?;

updateBlockPositionOnly:
UPDATE blocks SET position = ? WHERE uuid = ?;

-- Shift all root-level block positions in one statement (parent_uuid IS NULL).
-- Replaces the O(n) Kotlin loop that loaded all siblings then issued N individual UPDATEs.
shiftRootBlockPositionsFrom:
UPDATE blocks SET position = position + 1
WHERE page_uuid = ? AND parent_uuid IS NULL AND position >= ?;

-- Shift all child block positions under a given parent in one statement.
-- Replaces the O(n) Kotlin loop that loaded all siblings then issued N individual UPDATEs.
shiftChildBlockPositionsFrom:
UPDATE blocks SET position = position + 1
WHERE parent_uuid = ? AND position >= ?;

updateBlockContent:
UPDATE blocks SET content = ?, updated_at = ?, version = version + 1, content_hash = ? WHERE uuid = ?;

updateBlockFull:
UPDATE blocks SET
    page_uuid = ?, parent_uuid = ?, left_uuid = ?, content = ?,
    level = ?, position = ?, updated_at = ?, properties = ?,
    version = version + 1, content_hash = ?, block_type = ?
WHERE uuid = ?;

updateBlockLevelOnly:
UPDATE blocks SET level = ? WHERE uuid = ?;

updateBlockLeftUuid:
UPDATE blocks SET left_uuid = ? WHERE uuid = ?;

selectBlockByLeftUuid:
SELECT * FROM blocks WHERE left_uuid = ?;

selectLastChild:
SELECT * FROM blocks WHERE parent_uuid = ? ORDER BY position DESC LIMIT 1;

updateBlockProperties:
UPDATE blocks SET properties = ? WHERE uuid = ?;

countBlocks:
SELECT COUNT(*) FROM blocks;

deleteBlockByUuid:
DELETE FROM blocks WHERE uuid = ?;

deleteBlockChildren:
DELETE FROM blocks WHERE parent_uuid = ?;

deleteAllBlocks:
DELETE FROM blocks;

deleteBlocksByPageUuid:
DELETE FROM blocks WHERE page_uuid = ?;

deleteBlocksByPageUuids:
DELETE FROM blocks WHERE page_uuid IN ?;

insertBlock:
INSERT OR REPLACE INTO blocks (uuid, page_uuid, parent_uuid, left_uuid, content, level, position, created_at, updated_at, properties, version, content_hash, block_type)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

-- Used by saveBlocksDiff for toUpdate blocks: fires blocks_au (AFTER UPDATE OF content) instead
-- of the double blocks_ad+blocks_ai pair that INSERT OR REPLACE triggers on existing rows.
-- blocks_au only fires for content column changes, so structural-only diffs avoid FTS5 entirely.
updateBlockForSave:
UPDATE blocks
SET page_uuid = ?, parent_uuid = ?, left_uuid = ?, content = ?, level = ?,
    position = ?, updated_at = ?, properties = ?, version = ?, content_hash = ?, block_type = ?
WHERE uuid = ?;

selectBlocksHashByPageUuid:
SELECT uuid, content_hash FROM blocks WHERE page_uuid = ?;

-- Deduplication queries
selectBlocksByContentHash:
SELECT * FROM blocks WHERE content_hash = ? ORDER BY created_at;

selectDuplicateBlockHashes:
SELECT content_hash, COUNT(*) AS cnt
FROM blocks
WHERE content_hash IS NOT NULL
GROUP BY content_hash
HAVING COUNT(*) > 1
ORDER BY cnt DESC
LIMIT ?;

-- Page queries
selectPageByUuid:
SELECT * FROM pages WHERE uuid = ?;

selectPageByName:
SELECT * FROM pages WHERE name = ? LIMIT 1;

existsPageByUuid:
SELECT COUNT(*) FROM pages WHERE uuid = ?;

existsPageByName:
SELECT COUNT(*) FROM pages WHERE name = ?;

-- NOTE: there is intentionally no unpaginated `SELECT * FROM pages` (or unpaginated
-- unloaded-pages) query. Standing collectors of unbounded queries re-materialize the
-- entire table per write burst and OOM Android on 8 000+ page graphs. Whole-graph
-- consumers use PageRepository.getAllPagesSnapshot() (bounded batches over
-- selectAllPagesPaginated) or the selectPageNameEntries projection.
selectAllPagesPaginated:
SELECT * FROM pages ORDER BY name LIMIT ? OFFSET ?;

-- Bounded batch for background indexing. ORDER BY uuid gives a stable drain order so a
-- caller can advance OFFSET past permanently-failing rows without re-fetching them forever.
selectUnloadedPagesPaginated:
SELECT * FROM pages WHERE is_content_loaded = 0 ORDER BY uuid LIMIT ? OFFSET ?;

-- Caller must chunk sectionIds into batches of ≤500 (SQLITE_MAX_VARIABLE_NUMBER=999 on Android API < 30).
selectUnloadedPagesBySection:
SELECT * FROM pages WHERE is_content_loaded = 0 AND section_id IN ? ORDER BY uuid LIMIT ? OFFSET ?;

countUnloadedPages:
SELECT COUNT(*) FROM pages WHERE is_content_loaded = 0;

-- Names-only projection for the page-name suggestion index: no properties/file_path/etc.
-- materialization, so a standing observer stays cheap even on 8 000+ page graphs.
selectPageNameEntries:
SELECT name, is_journal FROM pages;

-- Per-chunk existence lookups for graph reconcile (bounded IN list, caller chunks ≤500
-- to stay under SQLITE_MAX_VARIABLE_NUMBER=999 on Android API < 30).
-- name is COLLATE NOCASE so matching is case-insensitive.
selectPagesByNames:
SELECT * FROM pages WHERE name IN ?;

selectJournalPagesByDates:
SELECT * FROM pages WHERE is_journal = 1 AND journal_date IN ?;

selectFavoritePages:
SELECT * FROM pages WHERE is_favorite = 1 ORDER BY name;

selectPagesByNamespace:
SELECT * FROM pages WHERE namespace = ? ORDER BY name LIMIT ? OFFSET ?;

selectPagesByNamespaceUnpaginated:
SELECT * FROM pages WHERE namespace = ? ORDER BY name;

countPagesByNamespace:
SELECT COUNT(*) FROM pages WHERE namespace = ?;

selectRecentlyUpdatedPages:
SELECT * FROM pages ORDER BY updated_at DESC LIMIT ?;

selectRecentlyCreatedPages:
SELECT * FROM pages ORDER BY created_at DESC LIMIT ?;

updatePageProperties:
UPDATE pages SET properties = ? WHERE uuid = ?;

updatePageName:
UPDATE pages SET name = ? WHERE uuid = ?;

updatePage:
UPDATE pages SET
    namespace = ?,
    file_path = ?,
    updated_at = ?,
    properties = ?,
    version = ?,
    is_favorite = ?,
    is_journal = ?,
    journal_date = ?,
    is_content_loaded = ?,
    section_id = ?
WHERE uuid = ?;

countPages:
SELECT COUNT(*) FROM pages;

deletePageByUuid:
DELETE FROM pages WHERE uuid = ?;

insertPage:
INSERT OR IGNORE INTO pages (uuid, name, namespace, file_path, created_at, updated_at, properties, version, is_favorite, is_journal, journal_date, is_content_loaded, section_id)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectJournalPages:
SELECT * FROM pages WHERE is_journal = 1 AND journal_date IS NOT NULL ORDER BY journal_date DESC LIMIT ? OFFSET ?;

selectJournalPageByDate:
SELECT * FROM pages WHERE is_journal = 1 AND journal_date = ? LIMIT 1;

selectJournalPageByDateAndSection:
SELECT * FROM pages WHERE is_journal = 1 AND journal_date = ? AND section_id = ? LIMIT 1;

selectPagesBySectionId:
SELECT * FROM pages WHERE section_id = ? ORDER BY name ASC LIMIT ? OFFSET ?;

updatePageFavorite:
UPDATE pages SET is_favorite = ? WHERE uuid = ?;

deleteAllPages:
DELETE FROM pages;

-- All page UUIDs reachable in 1 hop from a given page (outgoing or incoming links).
-- Used to compute graph-distance boost during search ranking.
selectNeighbourPageUuids:
SELECT DISTINCT to_b.page_uuid AS page_uuid
FROM block_references br
JOIN blocks from_b ON from_b.uuid = br.from_block_uuid
JOIN blocks to_b   ON to_b.uuid   = br.to_block_uuid
WHERE from_b.page_uuid = :pageUuid AND to_b.page_uuid != :pageUuid
UNION
SELECT DISTINCT from_b.page_uuid AS page_uuid
FROM block_references br
JOIN blocks from_b ON from_b.uuid = br.from_block_uuid
JOIN blocks to_b   ON to_b.uuid   = br.to_block_uuid
WHERE to_b.page_uuid = :pageUuid AND from_b.page_uuid != :pageUuid;

-- Reference queries
selectOutgoingReferences:
SELECT b.* FROM blocks b
INNER JOIN block_references br ON b.uuid = br.to_block_uuid
WHERE br.from_block_uuid = ?;

selectIncomingReferences:
SELECT b.* FROM blocks b
INNER JOIN block_references br ON b.uuid = br.from_block_uuid
WHERE br.to_block_uuid = ?;

insertBlockReference:
INSERT OR REPLACE INTO block_references (from_block_uuid, to_block_uuid, created_at)
VALUES (?, ?, ?);

deleteBlockReference:
DELETE FROM block_references WHERE from_block_uuid = ? AND to_block_uuid = ?;

selectOrphanedBlocks:
SELECT b.* FROM blocks b
LEFT JOIN block_references br ON b.uuid = br.to_block_uuid
WHERE br.id IS NULL;

selectMostConnectedBlocks:
SELECT b.*, COUNT(br.id) AS reference_count
FROM blocks b
LEFT JOIN block_references br ON b.uuid = br.to_block_uuid OR b.uuid = br.from_block_uuid
GROUP BY b.uuid
ORDER BY reference_count DESC
LIMIT ?;

-- Search queries
selectPagesByNameLike:
SELECT * FROM pages WHERE name LIKE ?;

selectPagesByNameLikePaginated:
SELECT * FROM pages WHERE name LIKE ? ORDER BY name LIMIT ? OFFSET ?;

selectBlocksReferencing:
SELECT DISTINCT b.* FROM blocks b
INNER JOIN block_references br ON b.uuid = br.from_block_uuid
WHERE br.to_block_uuid = ?;

-- Plugin data queries
selectPluginDataById:
SELECT * FROM plugin_data WHERE id = ?;

selectPluginDataByPlugin:
SELECT * FROM plugin_data WHERE plugin_id = ? ORDER BY created_at;

selectPluginDataByEntity:
SELECT * FROM plugin_data WHERE entity_type = ? AND entity_uuid = ? ORDER BY key;

selectPluginDataByKey:
SELECT * FROM plugin_data WHERE plugin_id = ? AND key = ? ORDER BY entity_type, entity_uuid;

selectPluginDataByPluginAndEntity:
SELECT * FROM plugin_data WHERE plugin_id = ? AND entity_type = ? AND entity_uuid = ? ORDER BY key;

countPluginDataByPlugin:
SELECT COUNT(*) FROM plugin_data WHERE plugin_id = ?;

countPluginDataByEntity:
SELECT COUNT(*) FROM plugin_data WHERE entity_type = ? AND entity_uuid = ?;

insertPluginData:
INSERT INTO plugin_data (plugin_id, entity_type, entity_uuid, key, value, created_at, updated_at)
VALUES (?, ?, ?, ?, ?, ?, ?);

updatePluginData:
UPDATE plugin_data SET value = ?, updated_at = ? WHERE plugin_id = ? AND entity_type = ? AND entity_uuid = ? AND key = ?;

upsertPluginData:
INSERT OR REPLACE INTO plugin_data (plugin_id, entity_type, entity_uuid, key, value, created_at, updated_at)
VALUES (?, ?, ?, ?, ?, ?, ?);

deletePluginData:
DELETE FROM plugin_data WHERE plugin_id = ? AND entity_type = ? AND entity_uuid = ? AND key = ?;

deletePluginDataByPlugin:
DELETE FROM plugin_data WHERE plugin_id = ?;

deletePluginDataByEntity:
DELETE FROM plugin_data WHERE entity_type = ? AND entity_uuid = ?;

existsPluginData:
SELECT COUNT(*) FROM plugin_data WHERE plugin_id = ? AND entity_type = ? AND entity_uuid = ? AND key = ?;

-- FTS5 Full-Text Search queries
searchBlocksByContentFts:
SELECT
    b.uuid,
    b.page_uuid,
    b.parent_uuid,
    b.left_uuid,
    b.content,
    b.level,
    b.position,
    b.created_at,
    b.updated_at,
    b.properties,
    b.version,
    highlight(blocks_fts, 0, '<em>', '</em>') AS highlight,
    bm25(blocks_fts) AS bm25_score
FROM blocks_fts bm
JOIN blocks b ON b.id = bm.rowid
WHERE blocks_fts MATCH :query
ORDER BY bm25(blocks_fts)
LIMIT :limit OFFSET :offset;

searchBlocksByContentFtsInPage:
SELECT
    b.uuid,
    b.page_uuid,
    b.parent_uuid,
    b.left_uuid,
    b.content,
    b.level,
    b.position,
    b.created_at,
    b.updated_at,
    b.properties,
    b.version,
    highlight(blocks_fts, 0, '<em>', '</em>') AS highlight,
    bm25(blocks_fts) AS bm25_score
FROM blocks_fts bm
JOIN blocks b ON b.id = bm.rowid
WHERE blocks_fts MATCH :query
AND b.page_uuid = :pageUuid
ORDER BY bm25(blocks_fts)
LIMIT :limit OFFSET :offset;

searchBlocksCountFts:
SELECT COUNT(*) AS result_count
FROM blocks_fts bm
WHERE blocks_fts MATCH :query;

-- FTS5 search for page names with BM25 ranking
searchPagesByNameFts:
SELECT
    p.uuid,
    p.name,
    p.namespace,
    p.file_path,
    p.created_at,
    p.updated_at,
    p.properties,
    p.version,
    p.is_favorite,
    p.is_journal,
    p.journal_date,
    p.is_content_loaded,
    highlight(pages_fts, 0, '<em>', '</em>') AS highlight,
    bm25(pages_fts) AS bm25_score
FROM pages_fts pf
JOIN pages p ON p.rowid = pf.rowid
WHERE pages_fts MATCH :query
ORDER BY bm25(pages_fts)
LIMIT :limit;

-- Date-ranged FTS queries for search with date filters
searchPagesByNameFtsInDateRange:
SELECT p.uuid, p.name, p.namespace, p.file_path, p.created_at, p.updated_at,
       p.properties, p.version, p.is_favorite, p.is_journal, p.journal_date,
       p.is_content_loaded,
       highlight(pages_fts, 0, '<em>', '</em>') AS highlight,
       bm25(pages_fts) AS bm25_score
FROM pages_fts pf
JOIN pages p ON p.rowid = pf.rowid
WHERE pages_fts MATCH :query
AND p.updated_at >= :startMs AND p.updated_at <= :endMs
ORDER BY bm25(pages_fts)
LIMIT :limit;

searchBlocksByContentFtsInDateRange:
SELECT b.uuid, b.page_uuid, b.parent_uuid, b.left_uuid, b.content, b.level,
       b.position, b.created_at, b.updated_at, b.properties, b.version,
       highlight(blocks_fts, 0, '<em>', '</em>') AS highlight,
       bm25(blocks_fts) AS bm25_score
FROM blocks_fts bm
JOIN blocks b ON b.id = bm.rowid
WHERE blocks_fts MATCH :query
AND b.updated_at >= :startMs AND b.updated_at <= :endMs
ORDER BY bm25(blocks_fts)
LIMIT :limit OFFSET :offset;

-- Visit tracking queries — two-step upsert (same pattern as histogram buckets)
insertPageVisitIfAbsent:
INSERT OR IGNORE INTO page_visits (page_uuid, visit_count, last_visited_at)
VALUES (?, 0, ?);

updatePageVisit:
UPDATE page_visits
SET visit_count = visit_count + 1, last_visited_at = ?
WHERE page_uuid = ?;

selectPageVisitsByUuids:
SELECT page_uuid, last_visited_at, visit_count
FROM page_visits
WHERE page_uuid IN ?;

selectPageVisitByUuid:
SELECT page_uuid, last_visited_at, visit_count
FROM page_visits
WHERE page_uuid = ?;

-- Count blocks that contain a [[pageName]] wikilink (for rename preview)
countBlocksWithWikilink:
SELECT COUNT(*) FROM blocks WHERE content LIKE '%[[' || :pageName || ']]%';

-- Select all blocks that contain a [[pageName]] wikilink (for rename backlink rewriting)
selectBlocksWithWikilink:
SELECT * FROM blocks WHERE content LIKE '%[[' || :pageName || ']]%' ORDER BY page_uuid, position;

-- Count blocks that contain a [[pageName]] wikilink (for All Pages backlink count)
countLinkedReferencesForPage:
SELECT COUNT(*) FROM blocks WHERE content LIKE '%[[' || :pageName || ']]%';

-- Read precomputed backlink counts for a batch of pages — O(1) per page via UUID index.
-- The backlink_count column is populated by the pages_backlink_count schema migration
-- and refreshed by rebuildFts() via a Kotlin-side single-pass scan.
selectBacklinkCountsForPages:
SELECT name AS page_name, backlink_count
FROM pages
WHERE uuid IN ?;

-- Recompute backlink count for a single page by name.
-- Called incrementally after block writes that add/remove wikilinks.
recomputeBacklinkCountForPage:
UPDATE pages SET backlink_count = (
    SELECT COUNT(*) FROM blocks
    WHERE blocks.content LIKE '%[[' || pages.name || ']]%'
) WHERE pages.name = ?;

-- Set backlink count directly (O(1) via idx_pages_name).
-- Used by rename: caller computes the new count arithmetically instead of scanning all blocks.
setPageBacklinkCount:
UPDATE pages SET backlink_count = ? WHERE name = ?;

-- Read backlink count for a single page (O(1) via idx_pages_name).
selectPageBacklinkCount:
SELECT backlink_count FROM pages WHERE name = ?;

-- Wikilink reference index queries (replace LIKE scan with O(1) index lookups).

insertWikilinkReference:
INSERT OR IGNORE INTO wikilink_references (block_uuid, page_name) VALUES (?, ?);

deleteWikilinkReferencesForBlock:
DELETE FROM wikilink_references WHERE block_uuid = ?;

deleteWikilinkReferencesForPageName:
DELETE FROM wikilink_references WHERE page_name = ? COLLATE NOCASE;

selectWikilinkPageNamesForBlock:
SELECT page_name FROM wikilink_references WHERE block_uuid = ?;

selectWikilinkPageNamesForBlocks:
SELECT DISTINCT page_name FROM wikilink_references WHERE block_uuid IN ?;

selectWikilinkPageNamesForPage:
SELECT DISTINCT page_name FROM wikilink_references
WHERE block_uuid IN (SELECT uuid FROM blocks WHERE page_uuid = ?);

-- O(1) backlink recount via index (replaces full-table LIKE scan).
recomputeBacklinkCountFromIndex:
UPDATE pages SET backlink_count = (
    SELECT COUNT(*) FROM wikilink_references WHERE page_name = pages.name COLLATE NOCASE
) WHERE pages.name = ?;

-- Batch version: recompute backlink counts for multiple pages in one UPDATE.
-- Replaces N individual recomputeBacklinkCountFromIndex calls on the hot-path edit.
recomputeBacklinkCountsForPages:
UPDATE pages SET backlink_count = (
    SELECT COUNT(*) FROM wikilink_references WHERE page_name = pages.name COLLATE NOCASE
) WHERE pages.name IN ?;

-- Rename all wikilink references from oldName to newName (single UPDATE, no LIKE scan).
-- UPDATE OR IGNORE: skips rows where (block_uuid, newName) already exists so the PRIMARY KEY
-- constraint is not violated when a block referenced both [[oldName]] and [[newName]].
updateWikilinkPageNameForRename:
UPDATE OR IGNORE wikilink_references SET page_name = :newName WHERE page_name = :oldName COLLATE NOCASE;

-- Metadata table for schema versioning and graph-level facts
CREATE TABLE metadata (
    key TEXT NOT NULL PRIMARY KEY,
    value TEXT NOT NULL
);

-- Named queries for metadata
upsertMetadata:
INSERT OR REPLACE INTO metadata (key, value) VALUES (?, ?);

selectMetadata:
SELECT value FROM metadata WHERE key = ?;

selectAllMetadata:
SELECT key, value FROM metadata;

-- UUID migration queries (one-shot, run once per graph)
updateBlockUuidForMigration:
UPDATE blocks SET uuid = ? WHERE uuid = ?;

updateParentUuidForMigration:
UPDATE blocks SET parent_uuid = ? WHERE parent_uuid = ?;

updateLeftUuidForMigration:
UPDATE blocks SET left_uuid = ? WHERE left_uuid = ?;

updateBlockReferencesFromForMigration:
UPDATE block_references SET from_block_uuid = ? WHERE from_block_uuid = ?;

updateBlockReferencesToForMigration:
UPDATE block_references SET to_block_uuid = ? WHERE to_block_uuid = ?;

updatePropertiesBlockUuidForMigration:
UPDATE properties SET block_uuid = ? WHERE block_uuid = ?;

selectAllBlocksWithPagePath:
SELECT b.uuid, b.parent_uuid, b.position, b.content, p.file_path
FROM blocks b
JOIN pages p ON b.page_uuid = p.uuid
WHERE p.file_path IS NOT NULL;

-- Operation log for persistent undo/redo and git-sync merge
CREATE TABLE operations (
    op_id       TEXT NOT NULL PRIMARY KEY,  -- UUID v7 (time-ordered for efficient range scans)
    session_id  TEXT NOT NULL,
    seq         INTEGER NOT NULL,            -- Lamport clock value (monotonically increasing per session)
    op_type     TEXT NOT NULL,               -- INSERT_BLOCK | UPDATE_BLOCK | DELETE_BLOCK | MOVE_BLOCK | BATCH_START | BATCH_END | SYNC_BARRIER
    entity_uuid TEXT,                        -- block UUID affected (NULL for BATCH_START/END and SYNC_BARRIER)
    page_uuid   TEXT,                        -- page context (NULL for BATCH_START/END and SYNC_BARRIER)
    payload     TEXT NOT NULL DEFAULT '{}',  -- JSON: {"before": {...}, "after": {...}}
    created_at  INTEGER NOT NULL
);

CREATE TABLE logical_clock (
    session_id  TEXT NOT NULL PRIMARY KEY,
    seq         INTEGER NOT NULL DEFAULT 0
);

CREATE INDEX idx_operations_session_seq ON operations(session_id, seq);
CREATE INDEX idx_operations_page ON operations(page_uuid);
CREATE INDEX idx_operations_entity ON operations(entity_uuid);

-- Operation log queries
insertOperation:
INSERT INTO operations (op_id, session_id, seq, op_type, entity_uuid, page_uuid, payload, created_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?);

selectOperationsBySessionDesc:
SELECT * FROM operations WHERE session_id = ? ORDER BY seq DESC LIMIT ?;

selectOperationsByPageUuid:
SELECT * FROM operations WHERE page_uuid = ? ORDER BY seq ASC;

selectOperationsSince:
SELECT * FROM operations WHERE session_id = ? AND seq > ? ORDER BY seq ASC;

deleteOperationsBefore:
DELETE FROM operations WHERE session_id = ? AND seq < ?;

countOperationPayloadSize:
SELECT SUM(LENGTH(payload)) FROM operations WHERE session_id = ?;

-- Logical clock queries
upsertLogicalClock:
INSERT OR REPLACE INTO logical_clock (session_id, seq) VALUES (?, ?);

selectLogicalClock:
SELECT seq FROM logical_clock WHERE session_id = ?;

-- Migration changelog queries
insertMigrationRecord:
INSERT INTO migration_changelog
    (id, graph_id, description, checksum, applied_at, execution_ms, status, applied_by, execution_order, changes_applied, error_message)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectAppliedMigrations:
SELECT id, checksum, status FROM migration_changelog WHERE graph_id = ? AND status = 'APPLIED' ORDER BY execution_order;

selectMigrationById:
SELECT * FROM migration_changelog WHERE id = ? AND graph_id = ?;

updateMigrationStatus:
UPDATE migration_changelog SET status = ?, error_message = ?, execution_ms = ?, changes_applied = ?
WHERE id = ? AND graph_id = ?;

selectRunningMigrations:
SELECT * FROM migration_changelog WHERE graph_id = ? AND status = 'RUNNING';

deleteMigrationRecord:
DELETE FROM migration_changelog WHERE id = ? AND graph_id = ?;

selectAllMigrationsForGraph:
SELECT * FROM migration_changelog WHERE graph_id = ? ORDER BY execution_order;

updateMigrationChecksum:
UPDATE migration_changelog SET checksum = ? WHERE id = ? AND graph_id = ?;

-- Maintenance: fold WAL frames into the main database file after bulk import.
-- Reduces WAL file size and speeds up subsequent opens.
pragmaWalCheckpointTruncate:
PRAGMA wal_checkpoint(TRUNCATE);

-- Git config table: one row per graph, stores all git synchronization settings
CREATE TABLE IF NOT EXISTS git_config (
    graph_id                TEXT NOT NULL PRIMARY KEY,
    repo_root               TEXT NOT NULL,
    wiki_subdir             TEXT NOT NULL DEFAULT '',
    remote_name             TEXT NOT NULL DEFAULT 'origin',
    remote_branch           TEXT NOT NULL DEFAULT 'main',
    auth_type               TEXT NOT NULL DEFAULT 'NONE',
    ssh_key_path            TEXT,
    ssh_key_passphrase_key  TEXT,
    https_token_key         TEXT,
    oauth_token_key         TEXT,
    poll_interval_minutes   INTEGER NOT NULL DEFAULT 5,
    auto_commit             INTEGER NOT NULL DEFAULT 1,
    commit_message_template TEXT NOT NULL DEFAULT 'SteleKit: {date}'
);

selectGitConfig:
SELECT * FROM git_config WHERE graph_id = ?;

insertOrReplaceGitConfig:
INSERT OR REPLACE INTO git_config(
    graph_id, repo_root, wiki_subdir, remote_name, remote_branch,
    auth_type, ssh_key_path, ssh_key_passphrase_key, https_token_key, oauth_token_key,
    poll_interval_minutes, auto_commit, commit_message_template
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

deleteGitConfig:
DELETE FROM git_config WHERE graph_id = ?;

-- Image annotations table: stores one row per imported image with calibration & sensor data.
-- The authoritative source is the sidecar JSON; this table is a query-optimised cache.
CREATE TABLE IF NOT EXISTS image_annotations (
    uuid                       TEXT NOT NULL PRIMARY KEY,
    block_uuid                 TEXT NOT NULL,
    page_uuid                  TEXT NOT NULL,
    graph_path                 TEXT NOT NULL,
    file_path                  TEXT NOT NULL,
    thumbnail_path             TEXT,
    source                     TEXT NOT NULL DEFAULT 'FILE',
    source_uri                 TEXT,
    captured_at_ms             INTEGER,
    imported_at_ms             INTEGER NOT NULL DEFAULT 0,
    calibration_method         TEXT NOT NULL DEFAULT 'NONE',
    pixels_per_meter           REAL NOT NULL DEFAULT 0.0,
    calibration_confidence_pct INTEGER NOT NULL DEFAULT 0,
    unit                       TEXT NOT NULL DEFAULT 'METERS',
    tags                       TEXT NOT NULL DEFAULT '[]',
    lat_lng                    TEXT,
    altitude_m                 REAL,
    bearing_deg                REAL,
    pitch_deg                  REAL,
    roll_deg                   REAL,
    focal_length_mm            REAL,
    focal_length_35mm_eq       REAL,
    camera_make                TEXT,
    camera_model               TEXT
);

CREATE INDEX IF NOT EXISTS idx_image_annotations_block_uuid ON image_annotations(block_uuid);
CREATE INDEX IF NOT EXISTS idx_image_annotations_page_uuid ON image_annotations(page_uuid);
CREATE INDEX IF NOT EXISTS idx_image_annotations_graph_path ON image_annotations(graph_path);
CREATE INDEX IF NOT EXISTS idx_image_annotations_imported_at ON image_annotations(imported_at_ms DESC);

-- Measurement annotations table: stores individual measurements drawn on an image.
-- Cascade-deletes when the parent image_annotation is deleted.
CREATE TABLE IF NOT EXISTS measurement_annotations (
    uuid              TEXT NOT NULL PRIMARY KEY,
    image_uuid        TEXT NOT NULL,
    annotation_type   TEXT NOT NULL,
    normalized_points TEXT NOT NULL DEFAULT '[]',
    value_meters      REAL,
    value_display     TEXT,
    label             TEXT,
    color_hex         TEXT NOT NULL DEFAULT '#FF0000',
    ble_device_id     TEXT,
    FOREIGN KEY (image_uuid) REFERENCES image_annotations(uuid) ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS idx_measurement_annotations_image_uuid ON measurement_annotations(image_uuid);

-- Image annotation queries

selectAllImageAnnotations:
SELECT * FROM image_annotations ORDER BY imported_at_ms DESC;

selectImageAnnotationByUuid:
SELECT * FROM image_annotations WHERE uuid = ?;

selectImageAnnotationsByPage:
SELECT * FROM image_annotations WHERE page_uuid = ? ORDER BY imported_at_ms DESC;

selectImageAnnotationsByTag:
SELECT * FROM image_annotations WHERE tags LIKE '%"' || ? || '"%' ORDER BY imported_at_ms DESC;

insertImageAnnotation:
INSERT OR REPLACE INTO image_annotations (
    uuid, block_uuid, page_uuid, graph_path, file_path, thumbnail_path,
    source, source_uri, captured_at_ms, imported_at_ms,
    calibration_method, pixels_per_meter, calibration_confidence_pct,
    unit, tags, lat_lng, altitude_m, bearing_deg, pitch_deg, roll_deg,
    focal_length_mm, focal_length_35mm_eq, camera_make, camera_model
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateImageAnnotation:
UPDATE image_annotations SET
    block_uuid = ?,
    page_uuid = ?,
    graph_path = ?,
    file_path = ?,
    thumbnail_path = ?,
    source = ?,
    source_uri = ?,
    captured_at_ms = ?,
    imported_at_ms = ?,
    calibration_method = ?,
    pixels_per_meter = ?,
    calibration_confidence_pct = ?,
    unit = ?,
    tags = ?,
    lat_lng = ?,
    altitude_m = ?,
    bearing_deg = ?,
    pitch_deg = ?,
    roll_deg = ?,
    focal_length_mm = ?,
    focal_length_35mm_eq = ?,
    camera_make = ?,
    camera_model = ?
WHERE uuid = ?;

deleteImageAnnotation:
DELETE FROM image_annotations WHERE uuid = ?;

-- Measurement annotation queries

selectMeasurementsForImage:
SELECT * FROM measurement_annotations WHERE image_uuid = ? ORDER BY rowid;

insertMeasurementAnnotation:
INSERT OR REPLACE INTO measurement_annotations (
    uuid, image_uuid, annotation_type, normalized_points,
    value_meters, value_display, label, color_hex, ble_device_id
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

deleteMeasurementsForImage:
DELETE FROM measurement_annotations WHERE image_uuid = ?;

deleteMeasurementAnnotation:
DELETE FROM measurement_annotations WHERE uuid = ?;

-- asset_index table: queryable metadata store for all graph assets
CREATE TABLE IF NOT EXISTS asset_index (
    uuid TEXT NOT NULL PRIMARY KEY,
    file_path TEXT NOT NULL,
    relative_path TEXT NOT NULL,
    media_type TEXT NOT NULL,
    subfolder TEXT NOT NULL DEFAULT 'files',
    tags TEXT NOT NULL DEFAULT '[]',
    auto_labels TEXT NOT NULL DEFAULT '[]',
    ocr_text TEXT,
    cloud_description TEXT,
    page_uuids TEXT NOT NULL DEFAULT '[]',
    size_bytes INTEGER NOT NULL DEFAULT 0,
    imported_at_ms INTEGER NOT NULL,
    ml_processed INTEGER NOT NULL DEFAULT 0,
    ml_attempted_at INTEGER,
    ml_failed INTEGER NOT NULL DEFAULT 0,
    content_hash TEXT,
    is_orphan INTEGER NOT NULL DEFAULT 0,
    ml_tags_source TEXT NOT NULL DEFAULT 'NONE'
);

CREATE UNIQUE INDEX IF NOT EXISTS idx_asset_file_path_unique ON asset_index(file_path);
CREATE INDEX IF NOT EXISTS idx_asset_unprocessed ON asset_index(ml_processed, ml_failed, imported_at_ms);
CREATE INDEX IF NOT EXISTS idx_asset_media_type ON asset_index(media_type);
CREATE INDEX IF NOT EXISTS idx_asset_imported_at ON asset_index(imported_at_ms DESC);

insertAsset:
INSERT INTO asset_index(uuid, file_path, relative_path, media_type, subfolder, tags, auto_labels, ocr_text, cloud_description, page_uuids, size_bytes, imported_at_ms, ml_processed, ml_failed, content_hash, is_orphan, ml_tags_source)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 0, 0, ?, 0, 'NONE');

insertAssetOrIgnore:
INSERT OR IGNORE INTO asset_index(uuid, file_path, relative_path, media_type, subfolder, tags, auto_labels, ocr_text, cloud_description, page_uuids, size_bytes, imported_at_ms, ml_processed, ml_failed, content_hash, is_orphan, ml_tags_source)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 0, 0, ?, 0, 'NONE');

selectAssetByUuid:
SELECT * FROM asset_index WHERE uuid = ?;

selectAssets:
SELECT * FROM asset_index ORDER BY imported_at_ms DESC LIMIT :limit OFFSET :offset;

selectAssetsByMediaType:
SELECT * FROM asset_index WHERE media_type = ? ORDER BY imported_at_ms DESC LIMIT :limit OFFSET :offset;

searchAssets:
SELECT * FROM asset_index WHERE (file_path LIKE :query ESCAPE '\' OR tags LIKE :query ESCAPE '\' OR auto_labels LIKE :query ESCAPE '\' OR ocr_text LIKE :query ESCAPE '\') ORDER BY imported_at_ms DESC LIMIT :limit OFFSET :offset;

selectUnprocessedAssets:
SELECT * FROM asset_index WHERE ml_processed = 0 AND ml_failed = 0 ORDER BY imported_at_ms ASC LIMIT :limit OFFSET :offset;

countUnprocessedAssets:
SELECT COUNT(*) FROM asset_index WHERE ml_processed = 0 AND ml_failed = 0;

countAssets:
SELECT COUNT(*) FROM asset_index;

updateAssetFilePath:
UPDATE asset_index SET file_path = :filePath, relative_path = :relativePath WHERE uuid = :uuid;

updateAssetTags:
UPDATE asset_index SET tags = :tags WHERE uuid = :uuid;

updateAssetAutoLabels:
UPDATE asset_index SET auto_labels = :autoLabels, ml_tags_source = :mlTagsSource WHERE uuid = :uuid;

updateAssetOcrText:
UPDATE asset_index SET ocr_text = :ocrText WHERE uuid = :uuid;

updateAssetCloudDescription:
UPDATE asset_index SET cloud_description = :cloudDescription, ml_tags_source = :mlTagsSource WHERE uuid = :uuid;

markAssetMlProcessed:
UPDATE asset_index SET ml_processed = 1, ml_attempted_at = :attemptedAt WHERE uuid = :uuid;

markAssetMlFailed:
UPDATE asset_index SET ml_failed = 1, ml_attempted_at = :attemptedAt WHERE uuid = :uuid;

updateAssetPageUuids:
UPDATE asset_index SET page_uuids = :pageUuids WHERE uuid = :uuid;

deleteAsset:
DELETE FROM asset_index WHERE uuid = :uuid;

-- Keyset pagination queries — BY_DATE_ADDED (single imported_at_ms cursor)
-- cursorMs=NULL means first page; COALESCE sentinel ensures all rows pass the predicate.

selectAssetsByDateKeyset:
SELECT * FROM asset_index
WHERE (imported_at_ms < COALESCE(:cursorMs, 9999999999999)
    OR (imported_at_ms = :cursorMs AND uuid < COALESCE(:cursorUuid, '')))
ORDER BY imported_at_ms DESC, uuid DESC
LIMIT :limit;

selectAssetsByMediaTypeByDateKeyset:
SELECT * FROM asset_index
WHERE media_type = :mediaType
AND (imported_at_ms < COALESCE(:cursorMs, 9999999999999)
    OR (imported_at_ms = :cursorMs AND uuid < COALESCE(:cursorUuid, '')))
ORDER BY imported_at_ms DESC, uuid DESC
LIMIT :limit;

selectAssetsBySearchByDateKeyset:
SELECT * FROM asset_index
WHERE (file_path LIKE :query ESCAPE '\' OR tags LIKE :query ESCAPE '\' OR auto_labels LIKE :query ESCAPE '\' OR ocr_text LIKE :query ESCAPE '\')
AND (imported_at_ms < COALESCE(:cursorMs, 9999999999999)
    OR (imported_at_ms = :cursorMs AND uuid < COALESCE(:cursorUuid, '')))
ORDER BY imported_at_ms DESC, uuid DESC
LIMIT :limit;

-- Keyset pagination queries — BY_NAME (compound file_path, uuid cursor)
-- cursorName=NULL means first page; COALESCE('') satisfies file_path > '' for all real paths.

selectAssetsByNameKeyset:
SELECT * FROM asset_index
WHERE (file_path > COALESCE(:cursorName, '') OR (file_path = :cursorName AND uuid > COALESCE(:cursorUuid, '')))
ORDER BY file_path ASC, uuid ASC
LIMIT :limit;

selectAssetsByMediaTypeByNameKeyset:
SELECT * FROM asset_index
WHERE media_type = :mediaType
AND (file_path > COALESCE(:cursorName, '') OR (file_path = :cursorName AND uuid > COALESCE(:cursorUuid, '')))
ORDER BY file_path ASC, uuid ASC
LIMIT :limit;

-- Keyset pagination queries — BY_SIZE (compound size_bytes DESC, uuid ASC cursor)
-- cursorSize=NULL means first page; COALESCE(Long.MAX_VALUE) ensures all rows pass.

selectAssetsBySizeKeyset:
SELECT * FROM asset_index
WHERE (size_bytes < COALESCE(:cursorSize, 9223372036854775807) OR (size_bytes = :cursorSize AND uuid > COALESCE(:cursorUuid, '')))
ORDER BY size_bytes DESC, uuid ASC
LIMIT :limit;

selectAssetsByMediaTypeBySizeKeyset:
SELECT * FROM asset_index
WHERE media_type = :mediaType
AND (size_bytes < COALESCE(:cursorSize, 9223372036854775807) OR (size_bytes = :cursorSize AND uuid > COALESCE(:cursorUuid, '')))
ORDER BY size_bytes DESC, uuid ASC
LIMIT :limit;

-- Orphaned assets — keyset paginated (imported_at_ms cursor, same sentinel pattern)

selectOrphanedAssets:
SELECT * FROM asset_index
WHERE is_orphan = 1
AND (imported_at_ms < COALESCE(:cursorMs, 9999999999999)
    OR (imported_at_ms = :cursorMs AND uuid < COALESCE(:cursorUuid, '')))
ORDER BY imported_at_ms DESC, uuid DESC
LIMIT :limit;

countOrphanedAssets:
SELECT COUNT(*) FROM asset_index WHERE is_orphan = 1;

-- Tags projection for Kotlin-side dedup; excludes empty/null JSON arrays.

selectAllTagsJson:
SELECT tags FROM asset_index WHERE tags IS NOT NULL AND tags != '' AND tags != '[]';

-- pending_asset_moves WAL table: holds in-flight moves for crash recovery
-- This table is expected to hold <= a handful of rows at any time -- unbounded reads are safe.
CREATE TABLE IF NOT EXISTS pending_asset_moves (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    asset_uuid TEXT NOT NULL,
    old_file_path TEXT NOT NULL,
    new_file_path TEXT NOT NULL,
    old_relative_path TEXT NOT NULL,
    new_relative_path TEXT NOT NULL,
    created_at_ms INTEGER NOT NULL
);

insertPendingMove:
INSERT INTO pending_asset_moves(asset_uuid, old_file_path, new_file_path, old_relative_path, new_relative_path, created_at_ms)
VALUES (?, ?, ?, ?, ?, ?);

deletePendingMove:
DELETE FROM pending_asset_moves WHERE id = ?;

selectAllPendingMoves:
SELECT * FROM pending_asset_moves;

selectLastInsertRowId:
SELECT last_insert_rowid();
