// ===== HIERARCHY VIEW CONVERSIONS =====

fun BlockHierarchyEntity.toBlock(): Block {
    return Block(
        id = 0L, // Not available in view
        uuid = this.uuid,
        pageId = 0L, // Not available in view
        parentId = null, // Would need to resolve from parent_uuid
        leftId = null,
        content = this.content,
        level = this.level_.toInt(),
        position = 0, // Not available in view
        createdAt = Instant.fromEpochMilliseconds(0), // Not available in view
        updatedAt = Instant.fromEpochMilliseconds(0), // Not available in view
        properties = emptyMap()
    )
}

fun BlockAncestryEntity.toBlock(): Block {
    return Block(
        id = 0L, // Not available in view
        uuid = this.uuid,
        pageId = 0L, // Not available in view
        parentId = this.parent_id,
        leftId = null,
        content = this.content,
        level = 0, // Not available in view
        position = 0, // Not available in view
        createdAt = Instant.fromEpochMilliseconds(0), // Not available in view
        updatedAt = Instant.fromEpochMilliseconds(0), // Not available in view
        properties = emptyMap()
    )
}

